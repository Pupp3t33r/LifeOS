{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Marten": "Warning"
      }
    },
    "Properties": {
      "service_name": "money"
    }
  },
  "AllowedHosts": "*",
  "Fx": {
    "Enabled": true,
    "FetchInterval": "01:00:00",
    "Currencies": ["BYN", "USD", "EUR", "RUB", "CNY", "PLN"],
    "PivotCurrency": "BYN",
    "SourcePriority": ["belarusbank", "frankfurter"],
    "BelarusbankUrl": "https://belarusbank.by/api/kurs_cards",
    "FrankfurterBaseUrl": "https://api.frankfurter.dev/v1",
    "StaleAfterDays": 3
  }
}
