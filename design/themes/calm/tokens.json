{
  "meta": {
    "name": "LifeOS — Calm",
    "description": "Canonical design tokens for the Calm theme. Single source of truth. Platform bindings (CSS, Dart) are derived from this file — see design/README.md.",
    "version": "0.2.0",
    "modes": ["light", "dark"],
    "modeConvention": "A token value is either a string (mode-independent) or an object { light, dark } (mode-aware)."
  },
  "color": {
    "bone":      { "light": "#F4F1EA", "dark": "#15120E" },
    "surface":   { "light": "#FBFAF6", "dark": "#211C16" },
    "ink":       { "light": "#2C2A26", "dark": "#EDE7DC" },
    "muted":     { "light": "#7C766B", "dark": "#9C9384" },
    "line":      { "light": "#E6E1D6", "dark": "#332D24" },
    "sage":      { "light": "#5E7E6B", "dark": "#8FB39E" },
    "sageDeep":  { "light": "#4E6B5A", "dark": "#A7C6B6" },
    "clay":      { "light": "#C07A52", "dark": "#D9966E" },
    "white":     "#FFFFFF",
    "focusRing": { "light": "rgba(94, 126, 107, 0.22)", "dark": "rgba(143, 179, 158, 0.32)" }
  },
  "font": {
    "display": "\"Manrope\", sans-serif",
    "body": "\"Manrope\", sans-serif"
  },
  "fontWeight": {
    "regular": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700
  },
  "radius": {
    "sm": "14px",
    "md": "18px",
    "lg": "28px",
    "pill": "999px"
  },
  "gradient": {
    "brand": "linear-gradient(150deg, #5E7E6B, #4E6B5A)"
  },
  "shadow": {
    "card":   { "light": "0 30px 60px -34px rgba(44, 42, 38, 0.40)", "dark": "0 30px 60px -28px rgba(0, 0, 0, 0.62)" },
    "raised": "0 14px 26px -12px rgba(94, 126, 107, 0.22)"
  }
}
