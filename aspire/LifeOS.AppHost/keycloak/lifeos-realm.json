{
  "realm": "lifeos",
  "enabled": true,
  "sslRequired": "none",
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "bruteForceProtected": false,
  "clients": [
    {
      "clientId": "money-api",
      "name": "Money API",
      "description": "Dev client for the Money service. Confidential with a known dev secret; password grant enabled for local testing. Audience mapper ensures 'aud: money-api' appears in access tokens (Keycloak 26 omits it by default).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "devsecret",
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:5221/*",
        "https://localhost:7103/*",
        "http://localhost:5022/*",
        "https://localhost:7038/*"
      ],
      "webOrigins": [
        "http://localhost:5221",
        "https://localhost:7103",
        "http://localhost:5022",
        "https://localhost:7038"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access"
      ],
      "protocolMappers": [
        {
          "name": "aud-money-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "money-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "devuser",
      "enabled": true,
      "emailVerified": true,
      "email": "dev@lifeos.local",
      "firstName": "Dev",
      "lastName": "User",
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "devpass",
          "temporary": false
        }
      ]
    }
  ]
}
