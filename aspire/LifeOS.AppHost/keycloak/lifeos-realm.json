{
  "realm": "lifeos",
  "displayName": "LifeOS",
  "enabled": true,
  "loginTheme": "lifeos",
  "sslRequired": "none",
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "bruteForceProtected": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 86400,
  "offlineSessionIdleTimeout": 5184000,
  "offlineSessionMaxLifespanEnabled": true,
  "offlineSessionMaxLifespan": 15552000,
  "revokeRefreshToken": true,
  "clients": [
    {
      "clientId": "money-api",
      "name": "Money API",
      "description": "Dev client for the Money service. Confidential with a known dev secret; password grant enabled for local testing. Audience mapper ensures 'aud: money-api' appears in access tokens (Keycloak 26 omits it by default).",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "devsecret",
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:5221/*",
        "https://localhost:7103/*",
        "http://localhost:5022/*",
        "https://localhost:7038/*"
      ],
      "webOrigins": [
        "http://localhost:5221",
        "https://localhost:7103",
        "http://localhost:5022",
        "https://localhost:7038"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access"
      ],
      "protocolMappers": [
        {
          "name": "aud-money-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "money-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "wallet-app",
      "name": "Wallet App",
      "description": "Public native/web client for the Wallet Flutter app. Authorization Code + PKCE (S256), no secret. Audience mapper adds 'aud: money-api' for Money JWT validation (ADR-0004). Shared lifeos realm — any LifeOS app reuses these credentials via SSO.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "+"
      },
      "redirectUris": [
        "dev.lifeos.wallet:/oauth2redirect",
        "dev.lifeos.wallet:/endsessionredirect",
        "http://localhost:5022/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "webOrigins": [
        "+"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access"
      ],
      "protocolMappers": [
        {
          "name": "aud-money-api",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "money-api",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "devuser",
      "enabled": true,
      "emailVerified": true,
      "email": "dev@lifeos.local",
      "firstName": "Dev",
      "lastName": "User",
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "devpass",
          "temporary": false
        }
      ],
      "realmRoles": ["offline_access"]
    },
    {
      "id": "a1a1a1a1-0000-4000-8000-000000000001",
      "username": "alice",
      "enabled": true,
      "emailVerified": true,
      "email": "alice@lifeos.local",
      "firstName": "Alice",
      "lastName": "Tester",
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "alicepass",
          "temporary": false
        }
      ],
      "realmRoles": ["offline_access"]
    },
    {
      "id": "b0b0b0b0-0000-4000-8000-000000000002",
      "username": "bob",
      "enabled": true,
      "emailVerified": true,
      "email": "bob@lifeos.local",
      "firstName": "Bob",
      "lastName": "Tester",
      "requiredActions": [],
      "credentials": [
        {
          "type": "password",
          "value": "bobpass",
          "temporary": false
        }
      ],
      "realmRoles": ["offline_access"]
    }
  ]
}
